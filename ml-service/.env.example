# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Database yang sama dengan yang dipakai Laravel (jenssegers/mongodb)
MONGO_URI=mongodb://localhost:27017/konekin_ml

# ── Path ──────────────────────────────────────────────────────────────────────
MODEL_DIR=./models
DATA_DIR=./data

# ── CORS (pisahkan dengan koma, tanpa spasi) ─────────────────────────────────
# Contoh: http://localhost:8000,http://127.0.0.1:8000
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
