            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{current_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{laravel_api}}/umkm/projects/{{project_id}}/applications"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.length > 0 && json.data[0].id) {",
                  "  pm.environment.set('application_id', json.data[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "POST",
            "header": [
              {
