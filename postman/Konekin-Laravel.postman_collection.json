    {
      "name": "Auth",
      "item": [
        {
          "name": "Register UMKM",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name_umkm}}\",\n  \"email\": \"{{email_umkm}}\",\n  \"password\": \"{{password}}\",\n  \"password_confirmation\": \"{{password}}\",\n  \"type\": \"umkm\",\n  \"phone\": \"{{phone_umkm}}\",\n  \"city\": \"{{city_umkm}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{laravel_api}}/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status is 201', function () {",
                  "  pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "pm.test('Registration succeeded', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "if (json && json.data && json.data.token) {",
                  "  pm.environment.set('current_token', json.data.token);",
                  "  pm.environment.set('token', json.data.token);",
                  "  pm.environment.set('current_user_id', json.data.user && json.data.user.id ? json.data.user.id : '');",
                  "  if (json.data.user && json.data.user.type === 'umkm') {",
                  "    pm.environment.set('umkm_token', json.data.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
